# Copy to .env and fill in. .env is git-ignored.

# --- LLM provider keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
XAI_API_KEY=xai-...

# --- Optional: Ollama (local open-weight judges) ---
# OLLAMA_HOST=http://localhost:11434

# --- Optional: Google Forms / Sheets OAuth (for human_annotation/) ---
# GOOGLE_OAUTH_CLIENT_SECRET_PATH=./client_secret.json
